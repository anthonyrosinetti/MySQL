	CAST(NULL AS INT64) AS compare_unreachable_mqls,
  	CAST(NULL AS INT64) AS compare_lost_contacts,
	CAST(NULL AS INT64) AS compare_clients_creation,
	CAST(NULL AS INT64) AS compare_clients_accounting,
	CAST(NULL AS INT64) AS compare_clients_direct_accounting,
	CAST(NULL AS INT64) AS compare_clients_crea_to_accounting,
	CAST(NULL AS INT64) AS compare_clients_invoicing_to_accounting
FROM
