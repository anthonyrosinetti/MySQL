	gender,
	age_range,
	eligible,
	legal_form,
	ape_activity_name,
	activity,
	first_conversion_form,
	first_conversion_form_category,
	first_conversion_form_type,
	first_page,
	first_page_category,
	contact_category,
	lost_reason,
	contact_type,
	treatment_type,
	source_name,
	channel,
	campaign_group,
	term,
  	CAST(NULL AS STRING) AS attribution_model_type,
	pack_choice,
	utm_source,
	utm_medium,
	utm_campaign,
	COUNT(DISTINCT CASE
      	WHEN
      		(date_mql < PARSE_DATE("%Y%m%d", @DS_END_DATE) OR DATE(date_opportunity) < PARSE_DATE("%Y%m%d", @DS_END_DATE) OR DATE(date_sql) < PARSE_DATE("%Y%m%d", @DS_END_DATE))
            AND
            (date_won_creation > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_creation IS NULL)
            AND
            (date_won_accounting > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_accounting IS NULL)            
            AND
            (date_lost > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_lost IS NULL)
      	THEN hubspot_contact_id END) AS open_mqls,
	COUNT(DISTINCT CASE
      	WHEN
      		(date_mql < PARSE_DATE("%Y%m%d", @DS_END_DATE) OR DATE(date_opportunity) < PARSE_DATE("%Y%m%d", @DS_END_DATE) OR DATE(date_sql) < PARSE_DATE("%Y%m%d", @DS_END_DATE))
            AND
            (date_won_creation > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_creation IS NULL)
            AND
            (date_won_accounting > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_accounting IS NULL)            
            AND
            (date_lost BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE))
            AND
            eligible = False
      	THEN hubspot_contact_id END) AS ineligible_mqls,
	COUNT(DISTINCT CASE
      	WHEN
      		(date_mql < PARSE_DATE("%Y%m%d", @DS_END_DATE) OR DATE(date_opportunity) < PARSE_DATE("%Y%m%d", @DS_END_DATE) OR DATE(date_sql) < PARSE_DATE("%Y%m%d", @DS_END_DATE))
            AND
            (date_won_creation > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_creation IS NULL)
            AND
            (date_won_accounting > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_accounting IS NULL)            
            AND
            (date_lost BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE))
            AND
            lost_reason IN ('[2] Injoignable','Injoignable')
      	THEN hubspot_contact_id END) AS unreachable_mqls,
	COUNT(DISTINCT CASE
      	WHEN
      		date_lost BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE)
      	THEN hubspot_contact_id END) AS lost_contacts,            
	COUNT(DISTINCT CASE
      	WHEN
      		date_won_creation BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE)
      	THEN hubspot_contact_id END) AS clients_creation,
	COUNT(DISTINCT CASE
      	WHEN
      		date_won_accounting BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE)
      	THEN hubspot_contact_id END) AS clients_accounting,
	COUNT(DISTINCT CASE
      	WHEN
            date_won_accounting BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE)
            AND
      		(date_won_invoicing IS NULL OR date_won_invoicing > date_won_accounting)
      		AND
      		(date_won_creation IS NULL OR date_won_creation > date_won_accounting)
      	THEN hubspot_contact_id END) AS clients_direct_accounting,
