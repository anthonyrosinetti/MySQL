SELECT DISTINCT
	hubspot_contact_id,
	dougs_user_id,
	hubspot_company_id,
	dougs_company_id,
	gender,
	age_range,
	legal_form,
	ape_activity_name,
	activity,
	first_conversion_form,
	lead_source,
	original_source,
	contact_category,
	contact_type,
	treatment_type,
    CAST(NULL AS STRING) AS attribution_model_type,
	FIRST_VALUE(CASE WHEN is_first_touch_attribution_model THEN source_name END IGNORE NULLS) OVER (PARTITION BY hubspot_contact_id ORDER BY touchpoint_timestamp ASC) AS source_name,
	FIRST_VALUE(CASE WHEN is_first_touch_attribution_model THEN channel END IGNORE NULLS) OVER (PARTITION BY hubspot_contact_id ORDER BY touchpoint_timestamp ASC) AS channel,
	FIRST_VALUE(CASE WHEN is_first_touch_attribution_model THEN campaign_group END IGNORE NULLS) OVER (PARTITION BY hubspot_contact_id ORDER BY touchpoint_timestamp ASC) AS campaign_group
FROM
    `data-production-398108.dbt_prod_marts.mart_touchpoints`
WHERE
	(date_mql BETWEEN PARSE_DATE("%Y%m%d", @DS_START_DATE) AND PARSE_DATE("%Y%m%d", @DS_END_DATE))
    AND
    (date_won_creation > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_creation IS NULL)
    AND
    (date_won_accounting > PARSE_DATE("%Y%m%d", @DS_START_DATE) OR date_won_accounting IS NULL)
