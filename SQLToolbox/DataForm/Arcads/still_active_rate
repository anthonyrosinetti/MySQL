CASE WHEN (SUM(CASE WHEN DATETIME_TRUNC(CURRENT_DATE(),MONTH) = DATETIME_TRUNC(DATE_ACTUAL,MONTH) THEN ACTIVE_WORKSPACES_BY_FIRST_PURCHASE_DATE END)
/
SUM(FIRST_PURCHASES_BY_FIRST_PURCHASE_DATE)) >= 1 THEN 1
ELSE SUM(CASE WHEN DATETIME_TRUNC(CURRENT_DATE(),MONTH) = DATETIME_TRUNC(DATE_ACTUAL,MONTH) THEN ACTIVE_WORKSPACES_BY_FIRST_PURCHASE_DATE END)
/
SUM(FIRST_PURCHASES_BY_FIRST_PURCHASE_DATE)
END
