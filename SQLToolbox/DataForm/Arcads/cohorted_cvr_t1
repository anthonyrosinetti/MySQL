SUM(CASE
	WHEN Time scale = "Daily" AND DATETIME_DIFF(DATE_ACTUAL,DATE_COHORT,DAY) <= 1 AND DATETIME_DIFF(CURRENT_DATE(),DATE_COHORT,DAY) >= 1 THEN FIRST_PURCHASES_BY_SIGNUP_DATE
	WHEN Time scale = "Weekly" AND DATETIME_DIFF(DATE_ACTUAL,DATE_COHORT,WEEK) <= 1 AND DATETIME_DIFF(CURRENT_DATE(),DATE_COHORT,WEEK) >= 1 THEN FIRST_PURCHASES_BY_SIGNUP_DATE
	WHEN Time scale = "Monthly" AND DATETIME_DIFF(DATE_ACTUAL,DATE_COHORT,MONTH) <= 1 AND DATETIME_DIFF(CURRENT_DATE(),DATE_COHORT,MONTH) >= 1 THEN FIRST_PURCHASES_BY_SIGNUP_DATE
END)/SUM(SIGNUPS_BY_SIGNUP_DATE)
